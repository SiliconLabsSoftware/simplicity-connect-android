<?xml version="1.0" encoding="utf-8"?>
<!-- Replace helvetica_neue_*.ttf with licensed Helvetica Neue files (same names). Current binaries are Stolzl placeholders so weights resolve. -->
<font-family xmlns:android="http://schemas.android.com/apk/res/android">
    <font
        android:fontStyle="normal"
        android:fontWeight="100"
        android:font="@font/helvetica_neue_thin" />
    <font
        android:fontStyle="normal"
        android:fontWeight="300"
        android:font="@font/helvetica_neue_light" />
    <font
        android:fontStyle="normal"
        android:fontWeight="400"
        android:font="@font/helvetica_neue_regular" />
    <font
        android:fontStyle="italic"
        android:fontWeight="400"
        android:font="@font/helvetica_neue_italic" />
    <font
        android:fontStyle="normal"
        android:fontWeight="500"
        android:font="@font/helvetica_neue_medium" />
    <font
        android:fontStyle="normal"
        android:fontWeight="700"
        android:font="@font/helvetica_neue_bold" />
</font-family>
