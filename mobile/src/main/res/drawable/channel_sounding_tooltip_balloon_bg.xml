<?xml version="1.0" encoding="utf-8"?>
<!-- Channel Sounding info Balloon: #ECECEC fill, 1dp top + bottom stroke #C5C5C5 (no side stroke). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/silabs_background" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item android:gravity="top">
        <shape android:shape="rectangle">
            <solid android:color="@color/silabs_redtheme_select_device_outline_color" />
            <size
                android:width="4096dp"
                android:height="1dp" />
        </shape>
    </item>
    <item android:gravity="bottom">
        <shape android:shape="rectangle">
            <solid android:color="@color/silabs_redtheme_select_device_outline_color" />
            <size
                android:width="4096dp"
                android:height="1dp" />
        </shape>
    </item>
</layer-list>
