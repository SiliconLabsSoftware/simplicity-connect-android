<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/silabs_background" />
            <corners
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp"
                android:topLeftRadius="@dimen/smart_lock_operate_top_corner_radius"
                android:topRightRadius="@dimen/smart_lock_operate_top_corner_radius" />
        </shape>
    </item>
    <item
        android:gravity="bottom|fill_horizontal"
        android:height="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/silabs_inactive_light" />
        </shape>
    </item>
</layer-list>
