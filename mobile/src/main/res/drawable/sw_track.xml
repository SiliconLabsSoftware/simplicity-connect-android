<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_enabled="true"
        android:state_checked="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <size
                        android:width="32dp"
                        android:height="18dp" />
                    <solid android:color="@color/silabs_transparent" />
                </shape>
            </item>
            <item
                android:bottom="3dp"
                android:top="2dp">
                <shape android:shape="rectangle">
                    <size
                        android:width="32dp"
                        android:height="13dp" />
                    <solid android:color="@color/silabs_red" />
                    <corners android:radius="7dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item
        android:state_enabled="true"
        android:state_checked="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <size
                        android:width="32dp"
                        android:height="18dp" />
                    <solid android:color="@color/silabs_transparent" />
                </shape>
            </item>
            <item
                android:bottom="3dp"
                android:top="2dp">
                <shape android:shape="rectangle">
                    <size
                        android:width="32dp"
                        android:height="13dp" />
                    <solid android:color="@color/silabs_inactive_light" />
                    <corners android:radius="7dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item
        android:state_enabled="false"
        android:state_checked="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <size
                        android:width="32dp"
                        android:height="18dp" />
                    <solid android:color="@color/silabs_transparent" />
                </shape>
            </item>
            <item
                android:bottom="3dp"
                android:top="2dp">
                <shape android:shape="rectangle">
                    <size
                        android:width="32dp"
                        android:height="13dp" />
                    <solid android:color="@color/track_disabled" />
                    <corners android:radius="7dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>