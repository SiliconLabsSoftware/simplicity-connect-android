<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="oval">
            <size
                android:width="18dp"
                android:height="18dp" />
            <solid android:color="@color/silabs_white" />
            <stroke
                android:width="1dp"
                android:color="@color/silabs_red" />
        </shape>
    </item>

    <item>
        <shape android:shape="oval">
            <size
                android:width="18dp"
                android:height="18dp" />
            <solid android:color="@color/silabs_white" />
            <stroke
                android:width="1dp"
                android:color="@color/silabs_inactive_light" />
        </shape>
    </item>
</selector>