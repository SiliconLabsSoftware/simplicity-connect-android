<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Drop shadow biased toward bottom (slightly below and larger than thumb) -->
    <item
        android:width="26dp"
        android:height="26dp"
        android:gravity="center"
        android:left="0dp"
        android:top="2dp">
        <shape android:shape="oval">
            <solid android:color="#38000000" />
        </shape>
    </item>
    <item
        android:width="24dp"
        android:height="24dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="@color/silabs_red" />
        </shape>
    </item>
</layer-list>
