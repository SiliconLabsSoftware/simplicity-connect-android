<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="@dimen/matter_12dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/matter_20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/stolzl_bold"
            android:text="@string/configure_wi_fi_ota_server"
            android:textColor="@color/silabs_redtheme_scanner_header_text_color"
            android:textSize="@dimen/text_size_SM"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dialog_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/matter_12dp"
            android:fontFamily="@font/stolzl_regular"
            android:lineSpacingExtra="2dp"
            android:text="@string/ota_demo_desc"
            android:textColor="@color/silabs_redtheme_scanner_body_text_color"
            android:textSize="@dimen/text_size_S" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/matter_16dp"
            android:baselineAligned="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/wifi_ip_address_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.38"
                android:fontFamily="@font/stolzl_medium"
                android:gravity="end|center_vertical"
                android:labelFor="@id/wifi_ip_address"
                android:text="@string/ip"
                android:textAlignment="viewEnd"
                android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                android:textSize="@dimen/text_size_SM" />

            <TextView
                android:id="@+id/wifi_ip_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/matter_12dp"
                android:layout_weight="0.62"
                android:fontFamily="@font/stolzl_regular"
                android:gravity="start|center_vertical"
                android:textAlignment="viewStart"
                android:textColor="@color/silabs_redtheme_button_fill_color"
                android:textSize="@dimen/text_size_SM"
                tools:text="192.168.1.123" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/matter_12dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/wifi_port_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.38"
                android:fontFamily="@font/stolzl_medium"
                android:gravity="end|center_vertical"
                android:labelFor="@id/port_id"
                android:text="@string/port"
                android:textAlignment="viewEnd"
                android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                android:textSize="@dimen/text_size_SM" />

            <EditText
                android:id="@+id/port_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/matter_12dp"
                android:layout_weight="0.62"
                android:background="@drawable/matter_add_device_name_input_bg"
                android:fontFamily="@font/stolzl_regular"
                android:gravity="center_vertical|start"
                android:importantForAutofill="no"
                android:inputType="number"
                android:maxLength="5"
                android:minHeight="@dimen/matter_45dp"
                android:paddingHorizontal="@dimen/matter_12dp"
                android:paddingVertical="@dimen/matter_10dp"
                android:text="5000"
                android:textAlignment="viewStart"
                android:textColor="@color/silabs_redtheme_button_fill_color"
                android:textColorHint="@color/silabs_redtheme_filer_hint_text_color"
                android:textSize="@dimen/text_size_SM" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/matter_20dp"
            android:fontFamily="@font/stolzl_regular"
            android:gravity="center"
            android:text="@string/heading_ota_choose_file"
            android:textAlignment="center"
            android:textColor="@color/silabs_redtheme_scanner_body_text_color"
            android:textSize="@dimen/text_size_S" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/matter_12dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/wifi_select_file_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.38"
                android:fontFamily="@font/stolzl_medium"
                android:gravity="end|center_vertical"
                android:labelFor="@id/select_app_file_btn"
                android:text="@string/select_file"
                android:textAlignment="viewEnd"
                android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                android:textSize="@dimen/text_size_SM" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/select_app_file_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/matter_12dp"
                android:layout_weight="0.62"
                android:background="@drawable/matter_add_device_name_input_bg"
                android:clickable="true"
                android:ellipsize="end"
                android:focusable="true"
                android:fontFamily="@font/stolzl_regular"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical|start"
                android:maxLines="2"
                android:minHeight="@dimen/matter_45dp"
                android:paddingHorizontal="@dimen/matter_12dp"
                android:paddingVertical="@dimen/matter_10dp"
                android:text="@string/select_rps_file"
                android:textColor="@color/silabs_redtheme_button_fill_color"
                android:textSize="@dimen/text_size_SM" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/matter_16dp"
            android:gravity="center_horizontal|center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ota_cancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/stolzl_medium"
                android:minWidth="@dimen/matter_100dp"
                android:text="@string/button_cancel"
                android:textAllCaps="false"
                android:textColor="@color/silabs_redtheme_button_fill_color"
                android:textSize="@dimen/text_size_SM"
                android:textStyle="bold"
                app:backgroundTint="@color/white"
                app:cornerRadius="@dimen/silabs_btn_radius"
                app:rippleColor="@color/sl_light_grey"
                app:strokeColor="@color/silabs_redtheme_button_fill_color"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ota_proceed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/matter_12dp"
                android:enabled="false"
                android:fontFamily="@font/stolzl_medium"
                android:minWidth="@dimen/matter_100dp"
                android:text="@string/btn_update"
                android:textAllCaps="false"
                android:textColor="@color/silabs_white"
                android:textSize="@dimen/text_size_SM"
                android:textStyle="bold"
                app:backgroundTint="@color/silabs_redtheme_button_fill_color"
                app:cornerRadius="@dimen/silabs_btn_radius"
                app:rippleColor="@color/sl_light_grey" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
