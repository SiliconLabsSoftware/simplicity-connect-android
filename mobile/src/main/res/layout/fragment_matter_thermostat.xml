<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/matter_thermostat_title"
        style="@style/Silabs_Rebranding_Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/matter_15dp"
        android:text="@string/matter_thermostat_cluster"
        android:textSize="@dimen/text_size_XL"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/display"
        android:layout_marginStart="@dimen/matter_8dp"
        android:layout_marginEnd="@dimen/matter_8dp"
        android:layout_width="match_parent"
        android:layout_height="@dimen/matter_150dp"
        android:layout_marginTop="80dp"
        app:cardCornerRadius="@dimen/matter_10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/matter_thermostat_title">

        <TextView
            android:id="@+id/txt_value"
            android:layout_width="@dimen/matter_200dp"
            android:layout_height="@dimen/matter_200dp"
            android:layout_gravity="center"
            android:layout_margin="@dimen/matter_10dp"
            android:fontFamily="@font/helvetica_neue_light"
            android:gravity="center"
            android:text="@string/matter_init_thermostat_value"
            android:textColor="@color/silabs_redtheme_primary_color"
            android:textSize="@dimen/text_size_XXXL" />
    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_read_value"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        style="@style/button_add_data_outlined"
        android:text="@string/refresh"
        android:layout_marginTop="@dimen/matter_100dp"
        app:cornerRadius="@dimen/matter_10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/display" />
</androidx.constraintlayout.widget.ConstraintLayout>