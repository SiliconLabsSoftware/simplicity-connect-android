<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/silabs_white"
        app:cardCornerRadius="@dimen/blinky_tb_card_corner_radius"
        app:cardElevation="@dimen/blinky_tb_card_elevation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/silabs_white"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="4dp"
                    android:fontFamily="@font/stolzl_medium"
                    android:text="@string/blinky_tb_rgb_leds"
                    android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                    android:textSize="@dimen/text_size_ML" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true">

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/iodemo_color_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:minWidth="32dp"
                        android:padding="0dp"
                        android:thumb="@drawable/sw_thumb"
                        app:splitTrack="false"
                        app:switchMinWidth="32dp"
                        app:track="@drawable/sw_track" />
                </LinearLayout>
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/silabs_divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/stolzl_medium"
                android:text="@string/blinky_tb_strength"
                android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                android:textSize="@dimen/text_size_SM" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="8dp">

                <com.siliconlabs.bledemo.features.demo.thunderboard_demos.demos.blinky_thunderboard.ui.ColorLEDs
                    android:id="@+id/iodemo_color_leds"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/color_led_height" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/silabs_divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/stolzl_medium"
                android:text="@string/blinky_tb_color"
                android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                android:textSize="@dimen/text_size_SM" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="8dp">

                <com.siliconlabs.bledemo.features.demo.thunderboard_demos.demos.blinky_thunderboard.ui.HueBackgroundView
                    android:id="@+id/iodemo_hue_background"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/space_SM"
                    android:layout_centerVertical="true" />

                <SeekBar
                    android:id="@+id/iodemo_hue_select"
                    style="@style/seekbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginBottom="@dimen/space_XXS"
                    android:thumb="@drawable/interface_knob" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/silabs_divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/stolzl_medium"
                android:text="@string/blinky_tb_brightness"
                android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                android:textSize="@dimen/text_size_SM" />

            <SeekBar
                android:id="@+id/iodemo_brightness_select"
                style="@style/seekbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:paddingBottom="0dp"
                android:thumb="@drawable/interface_knob" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/stolzl_medium"
                    android:text="-"
                    android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                    android:textSize="@dimen/text_size_SM" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/stolzl_medium"
                    android:text="+"
                    android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                    android:textSize="@dimen/text_size_SM" />
            </RelativeLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
