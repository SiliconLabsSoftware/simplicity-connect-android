<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_dialog_background"
    android:orientation="vertical"
    android:paddingTop="@dimen/matter_10dp"
    android:paddingBottom="@dimen/matter_10dp">

    <!-- Title TextView -->
    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/SilabsMatterDeviceTitle"
        android:gravity="left"
        android:paddingStart="@dimen/matter_10dp"
        android:paddingBottom="@dimen/matter_5dp"
        android:text="@string/matter_qr_code_info"
        android:textAppearance="?android:textAppearanceLarge"
        android:textColor="@color/black"
        android:textSize="17sp"
        android:textStyle="bold"
        tools:ignore="RtlHardcoded,RtlSymmetry" />

    <!-- Message TextView -->
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:background="@color/dialog_loading_spinner_start">

        <TextView
            android:id="@+id/dialog_message"
            android:layout_width="match_parent"
            style="@style/Silabs_Rebranding_Body"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:text="Message"
            android:textAppearance="?android:textAppearanceMedium"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="normal" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="@dimen/matter_10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_negative"
            style="@style/button_add_data_outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="32dp"
            android:textStyle="normal"
            android:layout_marginVertical="@dimen/space_S"
            android:textSize="@dimen/text_size_S"
            android:text="@string/button_cancel"
            app:cornerRadius="@dimen/silabs_btn_radius" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_positive"
            style="@style/Widget.MaterialComponents.Button"
            android:fontFamily="@font/stolzl_medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/space_S"
            android:text="@string/start_commissioning"
            android:textColor="@color/silabs_white"
            android:textSize="@dimen/text_size_S"
            android:textAllCaps="false"
            android:textStyle="normal"
            app:backgroundTint="@color/silabs_redtheme_button_fill_color"
            app:cornerRadius="@dimen/silabs_btn_radius" />
    </LinearLayout>
</LinearLayout>