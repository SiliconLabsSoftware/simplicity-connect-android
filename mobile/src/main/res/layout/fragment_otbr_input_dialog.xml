<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/matter_popup_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="@dimen/matter_20dp">

    <TextView
        android:id="@+id/tvTitle"
        style="@style/SilabsMatterDeviceTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/matter_alert_title"
        android:textColor="@color/black"
        android:textSize="@dimen/text_size_M"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMessage"
        style="@style/SilabsMatterDeviceBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/matter_10dp"
        android:gravity="center"
        android:text="@string/matter_otbr_alert_message"
        android:textColor="@color/black"
        android:textSize="@dimen/text_size_SM" />

    <EditText
        android:id="@+id/editText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/SilabsMatterDeviceBody"
        android:layout_marginTop="@dimen/matter_15dp"
        android:background="@drawable/wifi_config_inputs_group"
        android:gravity="top|start"
        android:inputType="textMultiLine|textNoSuggestions"
        android:minLines="6"
        android:minHeight="160dp"
        android:padding="@dimen/matter_15dp"
        android:scrollbars="vertical"
        android:textColor="@color/black"
        android:textSize="@dimen/text_size_SM" />

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/matter_1dp"
        android:layout_marginTop="@dimen/matter_20dp"
        android:background="@color/silabs_divider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/negativeBtn"
            style="@style/button_add_data_outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="32dp"
            android:textStyle="normal"
            android:layout_marginVertical="@dimen/space_S"
            android:textSize="@dimen/text_size_ML"
            android:text="@string/button_cancel"
            app:cornerRadius="@dimen/silabs_btn_radius" />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/positiveBtn"
            style="@style/Widget.MaterialComponents.Button"
            android:fontFamily="@font/stolzl_medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/space_S"
            android:text="@string/button_send"
            android:textColor="@color/silabs_white"
            android:textSize="@dimen/text_size_ML"
            android:textAllCaps="false"
            android:textStyle="normal"
            app:backgroundTint="@color/silabs_redtheme_button_fill_color"
            app:cornerRadius="@dimen/silabs_btn_radius" />
    </LinearLayout>
</LinearLayout>
