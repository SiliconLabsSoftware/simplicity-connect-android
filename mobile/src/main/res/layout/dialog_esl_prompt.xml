<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/dialog_card">

    <LinearLayout
        style="@style/dialog_margins"
        android:layout_marginHorizontal="@dimen/dialog_margin_horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/esl_prompt_title"
            style="@style/dialog_title"
            android:layout_marginBottom="@dimen/dialog_title_margin_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="@string/dialog_configure_tag_title" />

        <TextView
            android:id="@+id/esl_prompt_message"
            style="@style/dialog_text_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="@string/dialog_configure_tag_message" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dialog_button_margin_top"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/dialog_margin_between_buttons"
                android:fontFamily="@font/stolzl_medium"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textAllCaps="false"
                android:textColor="@color/silabs_redtheme_primary_color"
                android:textSize="@dimen/dialog_button_text_size"
                app:backgroundTint="@color/silabs_white"
                app:cornerRadius="@dimen/matter_10dp"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                app:minWidth="0dp"
                app:strokeColor="@color/silabs_redtheme_primary_color"
                app:strokeWidth="1dp"
                tools:text="@string/button_cancel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_configure"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/stolzl_medium"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textAllCaps="false"
                android:textColor="@color/silabs_white"
                android:textSize="@dimen/dialog_button_text_size"
                app:backgroundTint="@color/dialog_positive_button_selector"
                app:cornerRadius="@dimen/matter_10dp"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                app:minWidth="0dp"
                tools:text="@string/dialog_configure_btn_do_configure" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>