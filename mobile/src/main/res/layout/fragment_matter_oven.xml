<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/modal_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/matter_16dp">

        <!-- Oven Control Section (Top Card) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/matter_16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="@dimen/matter_8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/matter_16dp">

                <!-- Row 1: Oven status (left) + Unbind RangeHood button (top right) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/matter_16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_oven_label"
                            style="@style/Silabs_Rebranding_Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/matter_oven_label"
                            android:textColor="@color/masala"
                            android:textSize="@dimen/text_size_SM"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_oven_status"
                            style="@style/Silabs_Rebranding_Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/matter_8dp"
                            android:fontFamily="@font/stolzl_medium"
                            android:text="@string/matter_oven_off"
                            android:textColor="@color/silabs_red"
                            android:textSize="@dimen/text_size_SM"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_range_hood_binding"
                        style="@style/button_add_data_outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="30dp"
                        android:fontFamily="@font/stolzl_medium"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="@string/matter_oven_bind_to_rangehood"
                        android:textColor="@color/silabs_redtheme_button_text_color"
                        android:textAllCaps="false"
                        android:textSize="@dimen/text_size_SM"
                        app:cornerRadius="@dimen/matter_12dp"/>
                </LinearLayout>

                <!-- Row 2: Oven icon (left) + ON/OFF power button (right) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:background="@color/silabs_matter_oven_bg"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/iv_oven_icon"
                        android:layout_width="@dimen/matter_64dp"
                        android:layout_height="@dimen/matter_64dp"
                        android:contentDescription="@string/matter_oven_icon"
                        android:src="@drawable/ic_oven_matter" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_oven_off"
                        android:layout_width="@dimen/matter_200dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/matter_oven_power_pill_selector"
                        android:fontFamily="@font/stolzl_medium"
                        android:minHeight="52dp"
                        android:text="@string/matter_oven_off"
                        android:textAllCaps="true"
                        android:textColor="@color/silabs_white"
                        android:textSize="@dimen/text_size_SM" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Oven Mode Selection Section (Middle Card) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/matter_16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="@dimen/matter_8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/matter_16dp">

                <TextView
                    android:id="@+id/tv_oven_mode_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/matter_16dp"
                    android:fontFamily="@font/stolzl_regular"
                    android:text="@string/matter_oven_mode_label"
                    android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                    android:textSize="@dimen/text_size_SM"
                    android:textStyle="bold" />

                <!-- Mode Grid: 3x3, selected = blue bg + white icon/text + checkmark; unselected = white + light border -->
                <GridLayout
                    android:id="@+id/grid_oven_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alignmentMode="alignMargins"
                    android:background="@drawable/matter_oven_mode_grid_bg"
                    android:columnCount="3"
                    android:padding="@dimen/matter_5dp"
                    android:columnOrderPreserved="false"
                    android:rowCount="3"
                    android:useDefaultMargins="false">

                    <!-- Row 1: Bake, Convection, Grill -->
                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="@dimen/matter_100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/matter_8dp"
                        android:background="@drawable/bg_matter_oven_mode_cell">

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/btn_mode_bake"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:background="@color/white"
                            android:contentDescription="@string/matter_oven_mode_bake"
                            android:padding="@dimen/matter_8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_oven_matter_bake"
                            app:tint="@color/silabs_redtheme_primary_color" />

                        <TextView
                            android:id="@+id/tv_mode_bake"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:fontFamily="@font/stolzl_regular"
                            android:gravity="center"
                            android:padding="@dimen/matter_4dp"
                            android:text="@string/matter_oven_mode_bake"
                            android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                            android:textSize="@dimen/text_size_S"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_checkmark_bake"
                            android:layout_width="@dimen/matter_20dp"
                            android:layout_height="@dimen/matter_20dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="@dimen/matter_4dp"
                            android:contentDescription="@string/matter_oven_mode_selected"
                            android:src="@drawable/ic_checkmark"
                            android:visibility="gone"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="@dimen/matter_100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/matter_8dp"
                        android:background="@drawable/bg_matter_oven_mode_cell">

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/btn_mode_convection"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:background="@color/white"
                            android:contentDescription="@string/matter_oven_mode_convection"
                            android:padding="@dimen/matter_8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_oven_matter_convection"
                            app:tint="@color/silabs_redtheme_primary_color" />

                        <TextView
                            android:id="@+id/tv_mode_convection"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:fontFamily="@font/stolzl_regular"
                            android:gravity="center"
                            android:padding="@dimen/matter_4dp"
                            android:text="@string/matter_oven_mode_convection"
                            android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                            android:textSize="@dimen/text_size_S"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_checkmark_convection"
                            android:layout_width="@dimen/matter_20dp"
                            android:layout_height="@dimen/matter_20dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="@dimen/matter_4dp"
                            android:contentDescription="@string/matter_oven_mode_selected"
                            android:src="@drawable/ic_checkmark"
                            android:visibility="gone"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="@dimen/matter_100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/matter_8dp"
                        android:background="@drawable/bg_matter_oven_mode_cell">

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/btn_mode_grill"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:background="@color/white"
                            android:contentDescription="@string/matter_oven_mode_grill"
                            android:padding="@dimen/matter_8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/matter_oven_grill"
                            app:tint="@color/silabs_redtheme_primary_color" />

                        <TextView
                            android:id="@+id/tv_mode_grill"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:fontFamily="@font/stolzl_regular"
                            android:gravity="center"
                            android:padding="@dimen/matter_4dp"
                            android:text="@string/matter_oven_mode_grill"
                            android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                            android:textSize="@dimen/text_size_S"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_checkmark_grill"
                            android:layout_width="@dimen/matter_20dp"
                            android:layout_height="@dimen/matter_20dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="@dimen/matter_4dp"
                            android:contentDescription="@string/matter_oven_mode_selected"
                            android:src="@drawable/ic_checkmark"
                            android:visibility="gone"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <!-- Row 2: Roast, Clean, Convection Bake -->
                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="@dimen/matter_100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/matter_8dp"
                        android:background="@drawable/bg_matter_oven_mode_cell">

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/btn_mode_roast"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:background="@color/white"
                            android:contentDescription="@string/matter_oven_mode_roast"
                            android:padding="@dimen/matter_8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/matter_oven_roast"
                            app:tint="@color/silabs_redtheme_primary_color" />

                        <TextView
                            android:id="@+id/tv_mode_roast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:fontFamily="@font/stolzl_regular"
                            android:gravity="center"
                            android:padding="@dimen/matter_4dp"
                            android:text="@string/matter_oven_mode_roast"
                            android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                            android:textSize="@dimen/text_size_S"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_checkmark_roast"
                            android:layout_width="@dimen/matter_20dp"
                            android:layout_height="@dimen/matter_20dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="@dimen/matter_4dp"
                            android:contentDescription="@string/matter_oven_mode_selected"
                            android:src="@drawable/ic_checkmark"
                            android:visibility="gone"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="@dimen/matter_100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/matter_8dp"
                        android:background="@drawable/bg_matter_oven_mode_cell">

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/btn_mode_clean"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:background="@color/white"
                            android:contentDescription="@string/matter_oven_mode_clean"
                            android:padding="@dimen/matter_8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/matter_oven_clean"
                            app:tint="@color/silabs_redtheme_primary_color" />

                        <TextView
                            android:id="@+id/tv_mode_clean"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:fontFamily="@font/stolzl_regular"
                            android:gravity="center"
                            android:padding="@dimen/matter_4dp"
                            android:text="@string/matter_oven_mode_clean"
                            android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                            android:textSize="@dimen/text_size_S"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_checkmark_clean"
                            android:layout_width="@dimen/matter_20dp"
                            android:layout_height="@dimen/matter_20dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="@dimen/matter_4dp"
                            android:contentDescription="@string/matter_oven_mode_selected"
                            android:src="@drawable/ic_checkmark"
                            android:visibility="gone"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="@dimen/matter_100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/matter_8dp"
                        android:background="@drawable/bg_matter_oven_mode_cell">

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/btn_mode_convection_bake"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:background="@color/white"
                            android:contentDescription="@string/matter_oven_mode_convection_bake"
                            android:padding="@dimen/matter_8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/matter_oven_convection_bake"
                            app:tint="@color/silabs_redtheme_primary_color" />

                        <TextView
                            android:id="@+id/tv_mode_convection_bake"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:fontFamily="@font/stolzl_regular"
                            android:gravity="center"
                            android:padding="@dimen/matter_4dp"
                            android:text="@string/matter_oven_mode_convection_bake"
                            android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                            android:textSize="@dimen/text_size_S"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_checkmark_convection_bake"
                            android:layout_width="@dimen/matter_20dp"
                            android:layout_height="@dimen/matter_20dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="@dimen/matter_4dp"
                            android:contentDescription="@string/matter_oven_mode_selected"
                            android:src="@drawable/ic_checkmark"
                            android:visibility="gone"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <!-- Row 3: Convection Roast, Warming, Proofing -->
                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="@dimen/matter_100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/matter_8dp"
                        android:background="@drawable/bg_matter_oven_mode_cell">

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/btn_mode_convection_roast"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:background="@color/white"
                            android:contentDescription="@string/matter_oven_mode_convection_roast"
                            android:padding="@dimen/matter_8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/matter_oven_conv_roast"
                            app:tint="@color/silabs_redtheme_primary_color" />

                        <TextView
                            android:id="@+id/tv_mode_convection_roast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:fontFamily="@font/stolzl_regular"
                            android:gravity="center"
                            android:padding="@dimen/matter_4dp"
                            android:text="@string/matter_oven_mode_convection_roast"
                            android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                            android:textSize="@dimen/text_size_S"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_checkmark_convection_roast"
                            android:layout_width="@dimen/matter_20dp"
                            android:layout_height="@dimen/matter_20dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="@dimen/matter_4dp"
                            android:contentDescription="@string/matter_oven_mode_selected"
                            android:src="@drawable/ic_checkmark"
                            android:visibility="gone"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="@dimen/matter_100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/matter_8dp"
                        android:background="@drawable/bg_matter_oven_mode_cell">

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/btn_mode_warming"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:background="@color/white"
                            android:contentDescription="@string/matter_oven_mode_warming"
                            android:padding="@dimen/matter_8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/matter_oven_warming"
                            app:tint="@color/silabs_redtheme_primary_color" />

                        <TextView
                            android:id="@+id/tv_mode_warming"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:fontFamily="@font/stolzl_regular"
                            android:gravity="center"
                            android:padding="@dimen/matter_4dp"
                            android:text="@string/matter_oven_mode_warming"
                            android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                            android:textSize="@dimen/text_size_S"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_checkmark_warming"
                            android:layout_width="@dimen/matter_20dp"
                            android:layout_height="@dimen/matter_20dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="@dimen/matter_4dp"
                            android:contentDescription="@string/matter_oven_mode_selected"
                            android:src="@drawable/ic_checkmark"
                            android:visibility="gone"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="@dimen/matter_100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/matter_8dp"
                        android:background="@drawable/bg_matter_oven_mode_cell">

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/btn_mode_proofing"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:background="@color/white"
                            android:contentDescription="@string/matter_oven_mode_proofing"
                            android:padding="@dimen/matter_8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/matter_oven_proofing"
                            app:tint="@color/silabs_redtheme_primary_color" />

                        <TextView
                            android:id="@+id/tv_mode_proofing"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:fontFamily="@font/stolzl_regular"
                            android:gravity="center"
                            android:padding="@dimen/matter_4dp"
                            android:text="@string/matter_oven_mode_proofing"
                            android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                            android:textSize="@dimen/text_size_S"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_checkmark_proofing"
                            android:layout_width="@dimen/matter_20dp"
                            android:layout_height="@dimen/matter_20dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="@dimen/matter_4dp"
                            android:contentDescription="@string/matter_oven_mode_selected"
                            android:src="@drawable/ic_checkmark"
                            android:visibility="gone"
                            app:tint="@color/white" />
                    </FrameLayout>
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- RangeHood Control Section (Bottom Card) - visible only after successful binding -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_range_hood_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="@dimen/matter_8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/matter_16dp">

                <TextView
                    android:id="@+id/tv_range_hood_light_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/Silabs_Rebranding_Title"
                    android:text="@string/matter_range_hood_label"
                    android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                    android:textSize="@dimen/text_size_SM"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:background="@color/silabs_matter_oven_bg"
                    android:orientation="horizontal">

                    <!-- Light: icon + status -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/iv_range_hood_icon"
                            android:layout_width="@dimen/matter_40dp"
                            android:layout_height="@dimen/matter_40dp"
                            android:layout_marginEnd="@dimen/matter_8dp"
                            android:contentDescription="@string/matter_range_hood_icon"
                            android:scaleType="centerInside"
                            android:src="@drawable/matter_rangehood_light_on" />

                        <TextView
                            android:id="@+id/tv_range_hood_light_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/stolzl_regular"
                            android:text="@string/matter_range_hood_off"
                            android:textColor="@color/silabs_redtheme_scanner_header_text_color"
                            android:textSize="@dimen/text_size_SM"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Fan: icon + status -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@color/silabs_matter_oven_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/iv_range_hood_fan_icon"
