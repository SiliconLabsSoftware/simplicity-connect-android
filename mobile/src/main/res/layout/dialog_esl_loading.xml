<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    style="@style/dialog_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="24dp"
        android:orientation="vertical"
        android:color="@android:color/transparent"
        android:gravity="center">

        <ProgressBar
            android:indeterminateTint="@color/silabs_redtheme_bottom_navigation_active_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:progressTint="@color/silabs_redtheme_bottom_navigation_active_text"
            android:layout_marginBottom="12dp" />

        <TextView
            android:fontFamily="@font/stolzl_medium"
            android:textSize="14sp"
            android:textColor="@color/silabs_redtheme_iop_full_screen_txt_color"
            android:id="@+id/dialog_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Connecting with ESL tag..." />

        <androidx.appcompat.widget.AppCompatButton
            android:layout_gravity="bottom|center_horizontal"
            android:background="@drawable/channel_sounding_btn_reset_bg"
            android:visibility="gone"
            android:textColor="@color/silabs_redtheme_bottom_navigation_active_text"
            android:text="@string/button_cancel"
            android:layout_margin="@dimen/matter_10dp"
            android:textAllCaps="false"
            android:layout_width="wrap_content"
            android:id="@+id/button_cancel_upload"
            android:layout_height="@dimen/matter_30dp">
        </androidx.appcompat.widget.AppCompatButton>


    </LinearLayout>




</com.google.android.material.card.MaterialCardView>