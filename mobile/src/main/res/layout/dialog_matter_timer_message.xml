<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="@dimen/matter_4dp"
    app:cardElevation="6dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/matter_20dp">

        <TextView
            android:id="@+id/tv_timer_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/stolzl_regular"
            android:gravity="center"
            android:textAlignment="viewStart"
            android:textColor="@color/silabs_rebranding_2373_connected_light_text_color"
            android:textSize="@dimen/text_size_ML"
            tools:text="@string/matter_oven_binding_success_message"
            tools:ignore="RtlCompat" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/matter_20dp"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_timer_cancel"
                style="@style/button_add_data_outlined"
                android:layout_width="@dimen/matter_100dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/stolzl_bold"
                android:minWidth="0dp"
                android:paddingHorizontal="@dimen/matter_8dp"
                android:text="@string/matter_ok_btn"
                android:textAllCaps="true"
                android:textSize="@dimen/text_size_SM"
                android:textStyle="bold"
                app:cornerRadius="@dimen/matter_10dp"
                app:rippleColor="@color/sl_light_grey" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
