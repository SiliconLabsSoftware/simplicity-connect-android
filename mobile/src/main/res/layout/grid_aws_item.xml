<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <androidx.cardview.widget.CardView
        android:elevation="@dimen/matter_8dp"
        app:cardElevation="@dimen/matter_8dp"
        app:cardMaxElevation="@dimen/matter_8dp"
        android:id="@+id/cardview_env_tile"
        android:layout_width="@dimen/matter_100dp"
        android:layout_height="match_parent"
        android:layout_margin="4dp"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardCornerRadius="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/itemIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/space_XXXS"
                android:contentDescription=""
                tools:background="@drawable/ic_debug_prop_ext" />

            <TextView
                android:textColor="@color/silabs_dark_gray_text"
                android:textFontWeight="400"
                android:textSize="11sp"
                android:id="@+id/itemTitle"
                android:fontFamily="@font/stolzl_regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_XS"
                android:gravity="center"
                android:textAlignment="center"
                tools:text="Temperature" />

            <TextView
                android:textSize="14sp"
                android:textFontWeight="400"
                android:fontFamily="@font/stolzl_regular"
                android:textColor="@color/silabs_redtheme_iop_full_screen_txt_color"
                android:id="@+id/itemValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                tools:text="Value"
                android:textAlignment="center" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>