<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/dialog_card"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content" >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/space_S" >

        <com.google.android.material.textview.MaterialTextView
            style="@style/dialog_title"
            android:id="@+id/esl_ping_message_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dialog_loading_margin"
            android:layout_marginTop="@dimen/dialog_loading_margin"
            android:layout_marginEnd="@dimen/dialog_loading_margin"
            android:text="@string/ping_dialog_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/ping_message"
            android:fontFamily="@font/stolzl_regular"
            android:textSize="12sp"
            android:textColor="@color/silabs_redtheme_body_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dialog_loading_margin"
            android:layout_marginTop="@dimen/dialog_loading_margin"
            android:layout_marginEnd="@dimen/dialog_loading_margin"
            android:text="@string/ping_dialog_synchronized"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/esl_ping_message_title" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/okButton"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginStart="@dimen/dialog_loading_margin"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="@dimen/dialog_loading_margin"
            android:layout_marginBottom="@dimen/dialog_loading_margin"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:text="@android:string/ok"
            android:textAllCaps="false"
            android:textColor="@color/silabs_white"
            android:textSize="@dimen/dialog_button_text_size"
            app:backgroundTint="@color/silabs_redtheme_primary_color"
            app:cornerRadius="8dp"
            android:insetBottom="0dp"
            android:insetTop="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ping_message"
            app:minHeight="0dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>