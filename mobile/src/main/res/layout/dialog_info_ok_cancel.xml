<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal"
    style="@style/dialog_card">

    <LinearLayout
        style="@style/dialog_margins"
        android:layout_marginHorizontal="@dimen/dialog_margin_horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical" >

        <TextView
            android:id="@+id/tv_dialog_title"
            style="@style/dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dialog_title_margin_bottom"
            tools:text="@string/Leave_Application" />

        <ScrollView
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" >

                <TextView
                    android:id="@+id/tv_dialog_content"
                    style="@style/dialog_text_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_SM"
                    tools:text="@string/leave_application_info"/>

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/cb_dont_show_again"
                    style="@style/dialog_text_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:padding="@dimen/matter_2dp"
                    android:contentDescription="@string/Do_not_give_this_warning_again"
                    android:text="@string/Do_not_give_this_warning_again"
                    app:buttonCompat="@drawable/throughput_rb_notifications_square_selector" />

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/dialog_button_margin_top"
            android:layout_marginEnd="@dimen/dialog_button_margin_end"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_S"
                android:layout_weight="1"
                android:fontFamily="@font/stolzl_medium"
                android:minHeight="48dp"
                android:text="@string/button_cancel"
                android:textAllCaps="false"
                android:textColor="@color/silabs_redtheme_button_text_color"
                android:textStyle="bold"
                app:backgroundTint="@color/silabs_white"
                app:cornerRadius="@dimen/silabs_btn_radius"
                app:strokeColor="@color/silabs_redtheme_button_outline_color"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ok"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_S"
                android:layout_weight="1"
                android:fontFamily="@font/stolzl_medium"
                android:minHeight="48dp"
                android:text="@string/button_ok"
                android:textAllCaps="false"
                android:textColor="@color/silabs_white"
                android:textStyle="bold"
                app:backgroundTint="@color/silabs_redtheme_button_fill_color"
                app:cornerRadius="@dimen/silabs_btn_radius" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>