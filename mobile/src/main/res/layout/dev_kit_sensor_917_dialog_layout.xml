<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/matter_16dp"
    app:cardBackgroundColor="@color/silabs_white"
    app:cardCornerRadius="@dimen/matter_16dp"
    app:cardElevation="@dimen/motion_card_elevation"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/matter_24dp">

        <TextView
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/stolzl_bold"
            android:gravity="center_horizontal"
            android:textColor="@color/silabs_primary_text"
            android:textSize="@dimen/text_size_L"
            android:textStyle="bold"
            tools:text="Ambient Light Sensor" />

        <ImageView
            android:id="@+id/image"
            android:layout_width="@dimen/motion_devkit_dialog_icon_size"
            android:layout_height="@dimen/motion_devkit_dialog_icon_size"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/matter_20dp"
            android:contentDescription="@null"
            tools:src="@drawable/icon_light" />

        <TextView
            android:id="@+id/subTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/matter_8dp"
            android:fontFamily="@font/stolzl_regular"
            android:gravity="center_horizontal"
            android:textColor="@color/silabs_dark_gray_text"
            android:textSize="@dimen/adapter_label_medium_size"
            tools:text="Ambient Light" />

        <TextView
            android:id="@+id/txt_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/matter_24dp"
            android:fontFamily="@font/helvetica_neue_light"
            android:gravity="center"
            android:minHeight="@dimen/matter_80dp"
            android:text="@string/matter_init_value"
            android:textColor="@color/silabs_red"
            android:textSize="@dimen/text_size_XXXL"
            tools:text="212.68 lx" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/matter_24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/no_opt"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/stolzl_medium"
                android:minHeight="@dimen/matter_48dp"
                android:text="@string/close"
                android:textAllCaps="false"
                android:textColor="@color/silabs_redtheme_button_fill_color"
                android:textSize="@dimen/dialog_button_text_size"
                android:textStyle="bold"
                app:backgroundTint="@color/silabs_white"
                app:cornerRadius="@dimen/silabs_btn_radius"
                app:strokeColor="@color/silabs_redtheme_button_fill_color"
                app:strokeWidth="1dp" />

            <Space
                android:layout_width="@dimen/matter_12dp"
                android:layout_height="wrap_content" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/yes_opt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/stolzl_medium"
                android:minHeight="@dimen/matter_48dp"
                android:text="@string/refresh"
                android:textAllCaps="false"
                android:textColor="@color/silabs_white"
                android:textSize="@dimen/dialog_button_text_size"
                android:textStyle="bold"
                app:backgroundTint="@color/silabs_redtheme_button_fill_color"
                app:cornerRadius="@dimen/silabs_btn_radius"
                app:rippleColor="@color/sl_light_grey" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
