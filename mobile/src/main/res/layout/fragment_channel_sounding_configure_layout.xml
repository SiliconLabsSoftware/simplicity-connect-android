<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/modal_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:paddingBottom="16dp">

    <TextView
        android:id="@+id/configure_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/matter_15dp"
        android:fontFamily="@font/stolzl_medium"
        android:gravity="center_horizontal"
        android:includeFontPadding="false"
        android:text="@string/channel_sounding_configure_title"
        android:textColor="@color/silabs_redtheme_subheader_text_color"
        android:textSize="14sp" />

    <!-- ===== Configure Card (Figma rel_configure: 335 x 321, gap 5px) ===== -->
    <RelativeLayout
        android:id="@+id/rel_configure"
        android:layout_width="match_parent"
        android:layout_marginStart="@dimen/matter_10dp"
        android:layout_marginEnd="@dimen/matter_10dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/matter_30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/channel_sounding_configure_card_bg"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="20dp"
            android:paddingEnd="16dp"
            android:paddingBottom="20dp">

            <!-- ===== Measurement Frequency row (Figma lin_frequency: 303 x 36, gap 40) ===== -->
            <LinearLayout
                android:id="@+id/lin_frequency"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivInfoFreq"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@string/channel_sounding_tooltip_freq"
                    android:src="@drawable/ic_info_outline"
                    android:tooltipText="@string/channel_sounding_tooltip_freq" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/frequencyLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="0"
                    android:fontFamily="@font/stolzl_medium"
                    android:gravity="end"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="0dp"
                    android:text="@string/channel_sounding_config_freq_label"
                    android:textColor="@color/silabs_redtheme_subheader_text_color"
                    android:textSize="14sp" />

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="40dp"
                    android:background="@drawable/channel_sounding_configure_spinner_bg">

                    <Spinner
                        android:id="@+id/spinnerFrequency"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_centerVertical="true"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="28dp"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@string/channel_sounding_config_image_dropdown_arrow"
                        android:src="@drawable/channel_sounding_arrow_dropdown" />
                </RelativeLayout>
            </LinearLayout>

            <!-- ===== Measurement Count row (Figma lin_duration: same as lin_frequency) ===== -->
            <LinearLayout
                android:id="@+id/lin_duration"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivInfoDuration"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@string/channel_sounding_tooltip_duration"
                    android:src="@drawable/ic_info_outline"
                    android:tooltipText="@string/channel_sounding_tooltip_duration" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/durationLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="0"
                    android:fontFamily="@font/stolzl_medium"
                    android:gravity="end"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="0dp"
                    android:text="@string/channel_sounding_config_duration_label"
                    android:textColor="@color/silabs_redtheme_subheader_text_color"
                    android:textSize="14sp" />

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="40dp"
                    android:background="@drawable/channel_sounding_configure_spinner_bg">

                    <Spinner
                        android:id="@+id/spinnerDuration"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_centerVertical="true"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="28dp"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@string/channel_sounding_config_image_dropdown_arrow"
                        android:src="@drawable/channel_sounding_arrow_dropdown" />
                </RelativeLayout>
            </LinearLayout>

            <!-- Divider between Initiator Details and Kalman Filter -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="14dp"
                android:background="@color/silabs_inactive_light" />

            <!-- ===== Kalman Filter title row (centered: ⓘ + label) ===== -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivInfoKalmanFilter"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@string/channel_sounding_tooltip_kalman_filter"
                    android:src="@drawable/ic_info_outline"
                    android:tooltipText="@string/channel_sounding_tooltip_kalman_filter" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/kalmanFilterLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/stolzl_medium"
                    android:includeFontPadding="false"
                    android:text="Kalman Filter"
                    android:textColor="@color/silabs_redtheme_subheader_text_color"
                    android:textSize="14sp"
                    tools:ignore="HardcodedText" />

                <!-- Kept for backward compatibility (referenced in code), hidden visually -->
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchKalmanFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:visibility="gone"
                    app:thumbTint="@color/switch_thumb_color_selector"
                    app:trackTint="@color/switch_track_color_selector" />
            </LinearLayout>

            <!-- ===== Filtering Level row ===== -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/linear_filtering"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textFilteringLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/stolzl_medium"
                    android:includeFontPadding="false"
                    android:text="@string/channel_sounding_config_filtering_level_label"
                    android:textColor="@color/silabs_redtheme_subheader_text_color"
                    android:textSize="14sp" />

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/channel_sounding_configure_spinner_bg">

                    <Spinner
                        android:id="@+id/spinnerFilteringLevel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_centerVertical="true"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="28dp"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@string/channel_sounding_config_image_dropdown_arrow"
                        android:src="@drawable/channel_sounding_arrow_dropdown" />
                </RelativeLayout>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </LinearLayout>

        <!--
             "Initiator Details" title overlapping the top border of the card.
             Fixed 20dp height + center_vertical gravity puts the text vertical
             centre exactly on the card's top stroke (card has marginTop=10dp,
             text height 20dp -> centre at y=10dp). The white background "punches"
             a small gap in the border so the line breaks cleanly on each side.
        -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_alignParentTop="true"
            android:layout_marginStart="14dp"
            android:background="@color/silabs_white"
            android:fontFamily="@font/stolzl_medium"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="@string/channel_sounding_config_initiator_details"
            android:textColor="@color/silabs_redtheme_subheader_text_color"
            android:textSize="14sp" />
    </RelativeLayout>

    <!-- Kalman Filter Settings Section -->
    <RelativeLayout
        android:id="@+id/kalmanSettingsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="15dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/channel_sound_border"
            android:orientation="vertical"
            android:padding="25dp">

            <!-- Outlier Detection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/matter_5dp"
                android:layout_marginBottom="@dimen/matter_10dp"
                android:gravity="center"
                android:orientation="horizontal"
                tools:ignore="UselessParent">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/outlierDetectionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/stolzl_medium"
                    android:text="@string/channel_sounding_config_outlier_detection_label"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivInfoOutlierDetection"
                    android:layout_width="@dimen/matter_15dp"
                    android:layout_height="@dimen/matter_15dp"
                    android:layout_margin="@dimen/matter_5dp"
                    android:layout_marginEnd="@dimen/matter_15dp"
                    android:background="@drawable/ad_info"
                    android:tooltipText="@string/channel_sounding_tooltip_outlier_detection" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchOutlierDetection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/matter_15dp"
                    android:checked="true" />

            </LinearLayout>

            <!-- Adaptive Filtering -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/matter_5dp"
                android:layout_marginBottom="@dimen/matter_10dp"
                android:gravity="center"
                android:orientation="horizontal"
                tools:ignore="UselessParent">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/adaptiveFilteringLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/stolzl_medium"
                    android:text="@string/channel_sounding_config_adaptive_filtering_label"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivInfoAdaptiveFiltering"
                    android:layout_width="@dimen/matter_15dp"
                    android:layout_height="@dimen/matter_15dp"
                    android:layout_margin="@dimen/matter_5dp"
                    android:layout_marginEnd="@dimen/matter_15dp"
                    android:background="@drawable/ad_info"
                    android:tooltipText="@string/channel_sounding_tooltip_adaptive_filtering" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAdaptiveFiltering"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/matter_15dp"
                    android:checked="true" />

            </LinearLayout>

            <!-- Process Noise -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/matter_5dp"
                android:layout_marginBottom="@dimen/matter_10dp"
                android:gravity="center"
                android:orientation="horizontal"
                tools:ignore="UselessParent">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/processNoiseLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/stolzl_medium"
                    android:text="@string/channel_sounding_config_process_noise_label"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivInfoProcessNoise"
                    android:layout_width="@dimen/matter_15dp"
                    android:layout_height="@dimen/matter_15dp"
                    android:layout_margin="@dimen/matter_5dp"
                    android:layout_marginEnd="@dimen/matter_15dp"
                    android:background="@drawable/ad_info"
                    android:tooltipText="@string/channel_sounding_tooltip_process_noise" />

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/matter_15dp"
                    android:layout_marginEnd="3dp"
                    android:layout_weight=".38"
                    android:background="@drawable/channel_sounding_spinner_borders"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/spinnerProcessNoise"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:layout_marginStart="5dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:contentDescription="@string/channel_sounding_config_image_dropdown_arrow"
                        android:src="@drawable/channel_sounding_arrow_dropdown"
                        tools:ignore="ContentDescription" />

                </RelativeLayout>

            </LinearLayout>

            <!-- Measurement Noise -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/matter_5dp"
                android:layout_marginBottom="@dimen/matter_10dp"
                android:gravity="center"
                android:orientation="horizontal"
                tools:ignore="UselessParent">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/measurementNoiseLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/stolzl_medium"
                    android:text="@string/channel_sounding_config_measurement_noise_label"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivInfoMeasurementNoise"
                    android:layout_width="@dimen/matter_15dp"
                    android:layout_height="@dimen/matter_15dp"
                    android:layout_margin="@dimen/matter_5dp"
                    android:layout_marginEnd="@dimen/matter_15dp"
                    android:background="@drawable/ad_info"
                    android:tooltipText="@string/channel_sounding_tooltip_measurement_noise" />

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/matter_15dp"
                    android:layout_marginEnd="3dp"
                    android:layout_weight=".38"
                    android:background="@drawable/channel_sounding_spinner_borders"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/spinnerMeasurementNoise"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:layout_marginStart="5dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:contentDescription="@string/channel_sounding_config_image_dropdown_arrow"
                        android:src="@drawable/channel_sounding_arrow_dropdown"
                        tools:ignore="ContentDescription" />

                </RelativeLayout>

            </LinearLayout>

            <!-- Outlier Threshold -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/matter_5dp"
                android:layout_marginBottom="@dimen/matter_10dp"
                android:gravity="center"
                android:orientation="horizontal"
                tools:ignore="UselessParent">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/outlierThresholdLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/stolzl_medium"
                    android:text="@string/channel_sounding_config_outlier_threshold_label"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivInfoOutlierThreshold"
                    android:layout_width="@dimen/matter_15dp"
                    android:layout_height="@dimen/matter_15dp"
                    android:layout_margin="@dimen/matter_5dp"
                    android:layout_marginEnd="@dimen/matter_15dp"
                    android:background="@drawable/ad_info"
                    android:tooltipText="@string/channel_sounding_tooltip_outlier_threshold" />

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/matter_15dp"
                    android:layout_marginEnd="3dp"
                    android:layout_weight=".38"
                    android:background="@drawable/channel_sounding_spinner_borders"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/spinnerOutlierThreshold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:layout_marginStart="5dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:contentDescription="@string/channel_sounding_config_image_dropdown_arrow"
                        android:src="@drawable/channel_sounding_arrow_dropdown"
                        tools:ignore="ContentDescription" />

                </RelativeLayout>

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginStart="15dp"
            android:background="@color/silabs_white"
            android:fontFamily="sans-serif-condensed-light"
            android:text="@string/channel_sounding_config_kalman_settings"
            android:textColor="@color/black_text"
            android:textSize="17sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="15dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/channel_sound_border"
            android:orientation="vertical"
            android:padding="25dp">

            <!--Sensor Enabled-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/matter_5dp"
                android:layout_marginBottom="@dimen/matter_10dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/sensorEnabledLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/stolzl_medium"
                    android:text="@string/channel_sounding_config_sensor_enabled_label"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivInfoSensor"
                    android:layout_width="@dimen/matter_15dp"
                    android:layout_height="@dimen/matter_15dp"
                    android:layout_margin="@dimen/matter_5dp"
                    android:background="@drawable/ad_info"
                    android:tooltipText="@string/channel_sounding_tooltip_freq" />

                </LinearLayout>
                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/matter_15dp"
                    android:background="@drawable/channel_sounding_spinner_borders"
                    android:orientation="horizontal"
                    android:layout_weight="1">

                    <Spinner
                        android:id="@+id/spinnerSensorEnabled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:layout_marginStart="5dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:contentDescription="@string/channel_sounding_config_image_dropdown_arrow"
                        android:src="@drawable/channel_sounding_arrow_dropdown"
                        tools:ignore="ContentDescription" />
                </RelativeLayout>
            </LinearLayout>
            <!--  Security Level-->
            <LinearLayout
                android:id="@+id/securityLevelParent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/matter_5dp"
                android:layout_marginBottom="@dimen/matter_10dp"
                android:gravity="center"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/securityLevelLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/stolzl_medium"
                    android:text="@string/channel_sounding_config_security_level_details"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivInfoSecuity"
                    android:layout_width="@dimen/matter_15dp"
                    android:layout_height="@dimen/matter_15dp"
                    android:layout_marginEnd="@dimen/matter_15dp"

                    android:background="@drawable/ad_info"
                    android:tooltipText="@string/channel_sounding_tooltip_freq" />
                </LinearLayout>
                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="3dp"
                    android:background="@drawable/channel_sounding_spinner_borders"
                    android:orientation="horizontal"
                    android:layout_weight="1">

                    <Spinner
                        android:id="@+id/spinnerSecurityLevel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:layout_marginStart="5dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:contentDescription="@string/channel_sounding_config_image_dropdown_arrow"
                        android:src="@drawable/channel_sounding_arrow_dropdown"
                        tools:ignore="ContentDescription" />
                </RelativeLayout>

            </LinearLayout>

            <!-- Location Type-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/matter_5dp"
                android:layout_marginBottom="@dimen/matter_10dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/locationTypeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/stolzl_medium"
                        android:text="@string/channel_sounding_config_location_type_details"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/ivInfoLocatoin"
                        android:layout_width="@dimen/matter_15dp"
                        android:layout_height="@dimen/matter_15dp"
                        android:layout_marginEnd="@dimen/matter_15dp"
                        android:background="@drawable/ad_info"
                        android:tooltipText="@string/channel_sounding_tooltip_freq" />
                </LinearLayout>

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="3dp"
                    android:layout_weight="1"
                    android:background="@drawable/channel_sounding_spinner_borders"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/spinnerLocationType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:layout_marginStart="5dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:contentDescription="@string/channel_sounding_config_image_dropdown_arrow"
                        android:src="@drawable/channel_sounding_arrow_dropdown"
                        tools:ignore="ContentDescription" />
                </RelativeLayout>

            </LinearLayout>

            <!-- Sight Type -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/matter_5dp"
                android:layout_marginBottom="@dimen/matter_10dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="2"
                tools:ignore="UselessParent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/sightTypeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/stolzl_medium"
                        android:text="@string/channel_sounding_config_sight_type_details"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/ivInfoSighty"
                        android:layout_width="@dimen/matter_15dp"
                        android:layout_height="@dimen/matter_15dp"
                        android:layout_marginEnd="@dimen/matter_15dp"
                        android:background="@drawable/ad_info"
                        android:tooltipText="@string/channel_sounding_tooltip_freq" />
                </LinearLayout>


                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="3dp"
                    android:layout_weight="1"
                    android:background="@drawable/channel_sounding_spinner_borders"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/spinnerSightType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:layout_marginStart="5dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:contentDescription="@string/channel_sounding_config_image_dropdown_arrow"
                        android:src="@drawable/channel_sounding_arrow_dropdown"
                        tools:ignore="ContentDescription" />
                </RelativeLayout>

            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginStart="15dp"
            android:background="@color/silabs_white"
            android:fontFamily="sans-serif-condensed-light"
            android:text="@string/channel_sounding_config_ble_cs_config"
            android:textColor="@color/black_text"
            android:textSize="17sp"
            android:textStyle="bold" />

    </RelativeLayout>
    <!-- ===== Reset / Save Buttons (Figma: 122 x 30, gap 10, 10dp radius) ===== -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="@dimen/matter_10dp"
        android:gravity="center"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/resetBtn"
            android:layout_width="122dp"
            android:layout_height="30dp"
            android:background="@drawable/channel_sounding_btn_reset_bg"
            android:fontFamily="@font/stolzl_medium"
            android:gravity="center"
            android:includeFontPadding="false"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:stateListAnimator="@null"
            android:text="@string/channel_sounding_config_reset"
            android:textAllCaps="false"
            android:textColor="@color/silabs_redtheme_primary_color"
            android:textSize="14sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/saveBtn"
            android:layout_width="122dp"
            android:layout_height="30dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/channel_sounding_btn_save_bg"
            android:fontFamily="@font/stolzl_medium"
            android:gravity="center"
            android:includeFontPadding="false"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:stateListAnimator="@null"
            android:text="@string/channel_sounding_config_save"
            android:textAllCaps="false"
            android:textColor="@color/silabs_white"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
</ScrollView>
