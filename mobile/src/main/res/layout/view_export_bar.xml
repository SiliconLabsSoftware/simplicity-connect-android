<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rl_bottom_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="horizontal"
    android:background="@color/silabs_white">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/cancel_bar"
        style="@style/button_add_data_outlined"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="32dp"
        android:textStyle="normal"
        android:layout_marginVertical="@dimen/space_S"
        android:textSize="@dimen/text_size_ML"
        android:text="@string/button_cancel"
        app:cornerRadius="@dimen/silabs_btn_radius" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/export_bar"
        style="@style/Widget.MaterialComponents.Button"
        android:fontFamily="@font/stolzl_medium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/space_S"
        android:text="@string/button_export"
        android:textColor="@color/silabs_white"
        android:textSize="@dimen/text_size_ML"
        android:textAllCaps="false"
        android:textStyle="normal"
        app:backgroundTint="@color/silabs_redtheme_button_fill_color"
        app:cornerRadius="@dimen/silabs_btn_radius" />
</LinearLayout>