<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_background"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginVertical="4dp">

    <!-- Characteristic Name -->
    <TextView
        android:id="@+id/characteristic_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/silabs_primary_text"
        android:textSize="13sp"
        android:textStyle="bold"
        tools:text="Device Name" />

    <!-- Characteristic UUID -->
    <TextView
        android:id="@+id/characteristic_uuid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textColor="@color/silabs_subtle_text"
        android:textSize="10sp"
        tools:text="00002a00-0000-1000-8000-00805f9b34fb" />

    <!-- Properties Container -->
    <LinearLayout
        android:id="@+id/properties_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <!-- Property badges will be added programmatically -->

    </LinearLayout>

    <!-- Value (if readable) -->
    <TextView
        android:id="@+id/characteristic_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/badge_background_blue"
        android:padding="8dp"
        android:textColor="@color/silabs_primary_text"
        android:textSize="12sp"
        android:visibility="gone"
        tools:text="Value: EFR32" />

</LinearLayout>
